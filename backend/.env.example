# ─── Data paths (relative to backend/ working dir) ───
DATA_DIR=../data
FRONTEND_DIR=../frontend/dist

# ─── API Keys ───

# AISStream — live ship tracking (https://aisstream.io — free account)
AISSTREAM_API_KEY=your_key_here

# TomTom — traffic flow data (https://developer.tomtom.com — free 2500 req/day)
# TOMTOM_API_KEY=your_key_here

# OpenSky Network — flight tracking (https://opensky-network.org — free account)
# Anonymous: ~400 credits/day. Authenticated: ~4000 credits/day.
# Create API client at: https://opensky-network.org/my-opensky/account
# OPENSKY_CLIENT_ID=your_client_id
# OPENSKY_CLIENT_SECRET=your_client_secret

# ─── Server ───
BIND_ADDR=0.0.0.0:3000
RUST_LOG=info
